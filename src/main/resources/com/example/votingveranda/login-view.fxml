<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.votingveranda.LoginController"
            prefHeight="400.0"
            prefWidth="600.0">

    <children>

        <Label layoutX="250.0"
               layoutY="40.0"
               text="Login" />

        <Label layoutX="120.0"
               layoutY="120.0"
               text="Username:" />

        <TextField fx:id="usernameField"
                   layoutX="220.0"
                   layoutY="115.0"
                   prefWidth="200.0" />

        <Label layoutX="120.0"
               layoutY="180.0"
               text="Password:" />

        <PasswordField fx:id="passwordField"
                       layoutX="220.0"
                       layoutY="175.0"
                       prefWidth="200.0" />

        <Button fx:id="loginButton"
                layoutX="260.0"
                layoutY="260.0"
                text="Login"
                onAction="#handleLogin"/>

    </children>

</AnchorPane>